{
  "version": "1.0",
  "description": "Regras de pontuação de risco contratual",
  "risk_levels": {
    "low": {
      "min": 0,
      "max": 33,
      "label": "Baixo risco",
      "color": "green",
      "icon": "🟢"
    },
    "medium": {
      "min": 34,
      "max": 66,
      "label": "Médio risco",
      "color": "yellow",
      "icon": "🟡"
    },
    "high": {
      "min": 67,
      "max": 100,
      "label": "Alto risco",
      "color": "red",
      "icon": "🔴"
    }
  },
  "base_risk_scores": {
    "objeto": 5,
    "partes": 5,
    "definicoes": 5,
    "vigencia": 15,
    "renovacao": 25,
    "pagamento": 20,
    "reajuste": 25,
    "multa": 30,
    "penalidade": 30,
    "juros_mora": 15,
    "rescisao": 25,
    "aviso_previo": 15,
    "distrato": 15,
    "foro": 15,
    "arbitragem": 20,
    "mediacao": 10,
    "confidencialidade": 20,
    "nao_concorrencia": 25,
    "nao_solicitacao": 15,
    "propriedade_intelectual": 20,
    "licenca": 15,
    "cessao_direitos": 25,
    "limitacao_responsabilidade": 30,
    "indenizacao": 25,
    "garantia": 15,
    "seguros": 10,
    "sla": 20,
    "disponibilidade": 15,
    "suporte": 10,
    "entrega": 15,
    "protecao_dados": 30,
    "compartilhamento_dados": 35,
    "consentimento_dados": 25,
    "transferencia_internacional": 30,
    "retencao_dados": 25,
    "obrigacoes_contratante": 10,
    "obrigacoes_contratado": 10,
    "forca_maior": 15,
    "subcontratacao": 15,
    "cancelamento": 20,
    "disposicoes_gerais": 5,
    "comunicacoes": 5,
    "nao_classificado": 20
  },
  "abuse_severity_weights": {
    "high": 30,
    "medium": 15,
    "low": 5
  },
  "category_weights": {
    "financeiro": 1.2,
    "responsabilidade": 1.1,
    "privacidade": 1.3,
    "operacional": 1.0,
    "propriedade_intelectual": 1.0
  },
  "detection_rules": {
    "multa_desproporcional": {
      "description": "Multa acima de 20% do valor do contrato ou acima de 3 meses",
      "penalty": 30,
      "thresholds": {
        "percentage_warning": 20,
        "percentage_critical": 50,
        "months_warning": 3,
        "months_critical": 6
      }
    },
    "renovacao_automatica": {
      "description": "Renovação automática sem mecanismo claro de cancelamento",
      "penalty": 20,
      "mitigated_if": ["aviso_previo >= 30 dias", "cancelamento simples"]
    },
    "limitacao_responsabilidade": {
      "description": "Exclusão total ou quase total de responsabilidade",
      "penalty": 35,
      "acceptable_limits": ["valor do contrato", "12 meses de pagamento"]
    },
    "alteracao_unilateral": {
      "description": "Permissão para alterar termos sem consentimento",
      "penalty": 30,
      "mitigated_if": ["notificação prévia >= 30 dias", "direito de rescisão sem multa"]
    },
    "renuncia_direitos": {
      "description": "Renúncia genérica ou ampla de direitos legais",
      "penalty": 35,
      "never_acceptable": ["direitos do consumidor", "direitos trabalhistas"]
    },
    "dados_sem_finalidade": {
      "description": "Coleta ou uso de dados sem especificação de finalidade",
      "penalty": 30,
      "required_elements": [
        "finalidade específica",
        "base legal (Art. 7, LGPD)",
        "prazo de retenção",
        "direitos do titular"
      ]
    },
    "foro_distante": {
      "description": "Eleição de foro que prejudica uma das partes",
      "penalty": 15,
      "note": "Em relações de consumo, o foro é do domicílio do consumidor"
    },
    "irrevogabilidade_absoluta": {
      "description": "Irrevogabilidade que elimina direito de arrependimento",
      "penalty": 20,
      "note": "Art. 49 CDC garante arrependimento em 7 dias para compras fora do estabelecimento"
    }
  },
  "scoring_formula": {
    "description": "Score final = média ponderada dos scores por cláusula + penalidades por detecções abusivas",
    "clause_weight": {
      "with_abuse": 2.0,
      "without_abuse": 1.0
    },
    "category_adjustment": {
      "high_risk_categories_bonus": 0.1,
      "description": "Para cada categoria de alto risco, o score geral é multiplicado por (1 + N * 0.1)"
    },
    "cap": 100
  }
}
